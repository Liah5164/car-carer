# Required: Anthropic API key for the chat agent (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required: OpenRouter API key for document extraction (Gemini Flash)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Database (default: SQLite in project root)
DATABASE_URL=sqlite:///./care.db

# Upload directory (default: ./uploads)
UPLOAD_DIR=./uploads

# Optional overrides (uncomment to customize)
# JWT_EXPIRE_HOURS=72
# BATCH_MAX_CONCURRENT=3
# BATCH_MAX_FILES=100
# EXTRACTION_TIMEOUT=60
# EXTRACTION_MODEL=google/gemini-2.5-flash
# MAX_PHOTO_SIZE_MB=10
